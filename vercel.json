{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "functions": {
    "api/analyze.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/api/.*",
      "dest": "/api/$1"
    },
    {
      "src": "^/(?!api/).*",
      "dest": "/index.html"
    }
  ]
}
